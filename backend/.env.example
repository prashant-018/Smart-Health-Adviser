# Copy this file to .env and fill in your values (never commit .env to git!)
FLASK_ENV=production
FLASK_PORT=5000

# Gemini API key
GEMINI_API_KEY=your_gemini_api_key_here

# Google Maps / Geoapify API key for nearby hospitals feature
GEOAPIFY_API_KEY=your_key_here

# ── CORS: allowed frontend origins ───────────────────────────────────────────
# Set these in your Render dashboard → Environment Variables (NOT in .env on Render).
#
# Exact origin(s) — comma-separated if multiple:
# FRONTEND_ORIGINS=https://smart-health-adviser.vercel.app
#
# Optional: allow ALL Vercel preview/branch deploy URLs (regex):
# FRONTEND_ORIGINS_REGEX=https://.*\.vercel\.app
# ─────────────────────────────────────────────────────────────────────────────

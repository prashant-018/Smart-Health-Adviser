# Copy this file to .env for local development (never commit .env to git!)
# -----------------------------------------------------------------
# LOCAL development — Flask running on your machine:
REACT_APP_API_BASE_URL=http://127.0.0.1:5000

# PRODUCTION (Render backend) — add this in Vercel → Settings → Environment Variables:
# REACT_APP_API_BASE_URL=https://smart-health-adviser-1.onrender.com
# GROQ_API_KEY
REACT_APP_API_BASE_URL=http://127.0.0.1:5000